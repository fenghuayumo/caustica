[submodule]
	shallow = false
[submodule "External/RayTracingDenoiser"]
	path = External/Nrd
	url = https://github.com/NVIDIA-RTX/NRD.git
	shallow = false
[submodule "External/Opacity-MicroMap-SDK"]
	path = External/Omm
	url = https://github.com/NVIDIA-RTX/OMM.git
	branch = main-minimal
	shallow = false
[submodule "External/NVAPI"]
	path = External/NVAPI
	url = https://github.com/NVIDIA/nvapi.git
	shallow = false
[submodule "External/cxxopts"]
	path = External/cxxopts
	url = https://github.com/jarro2783/cxxopts.git
	shallow = false
[submodule "External/rtxdi-runtime"]
	path = External/Rtxdi
	url = https://github.com/fenghuayumo/RTXDI-Library.git
	shallow = false
[submodule "Assets"]
	path = Assets
	url = https://github.com/NVIDIA-RTX/caustica-Assets.git
	shallow = true
[submodule "External/Rtxtf"]
	path = External/Rtxtf
	url = https://github.com/NVIDIA-RTX/RTXTF-Library.git
	shallow = false
[submodule "External/cgltf"]
	path = External/cgltf
	url = https://github.com/jkuhlmann/cgltf
[submodule "External/glfw"]
	path = External/glfw
	url = https://github.com/glfw/glfw.git
[submodule "External/stb"]
	path = External/stb
	url = https://github.com/nothings/stb.git
[submodule "External/nvrhi"]
	path = External/nvrhi
	url = https://github.com/NVIDIA-RTX/NVRHI.git
[submodule "External/ShaderMake"]
	path = External/ShaderMake
	url = https://github.com/NVIDIA-RTX/ShaderMake.git
[submodule "External/imgui"]
	path = External/imgui
	url = https://github.com/ocornut/imgui
