[submodule "External/RayTracingDenoiser"]
	path = External/Nrd
	url = https://github.com/NVIDIA-RTX/NRD.git
	shallow = false
[submodule "External/NVAPI"]
	path = External/NVAPI
	url = https://github.com/NVIDIA/nvapi.git
	shallow = false
[submodule "External/cxxopts"]
	path = External/cxxopts
	url = https://github.com/jarro2783/cxxopts.git
	shallow = false
[submodule "Assets"]
	path = Assets
	url = https://github.com/NVIDIA-RTX/caustica-Assets.git
	shallow = true
[submodule "External/cgltf"]
	path = External/cgltf
	url = https://github.com/jkuhlmann/cgltf
[submodule "External/glfw"]
	path = External/glfw
	url = https://github.com/glfw/glfw.git
[submodule "External/stb"]
	path = External/stb
	url = https://github.com/nothings/stb.git
[submodule "External/ShaderMake"]
	path = External/ShaderMake
	url = https://github.com/NVIDIA-RTX/ShaderMake.git
[submodule "External/imgui"]
	path = External/imgui
	url = https://github.com/ocornut/imgui
[submodule "rtxmu"]
	path = rtxmu
	url = https://github.com/NVIDIA-RTX/RTXMU.git
[submodule "thirdparty/Vulkan-Headers"]
	path = thirdparty/Vulkan-Headers
	url = https://github.com/KhronosGroup/Vulkan-Headers.git
[submodule "thirdparty/DirectX-Headers"]
	path = thirdparty/DirectX-Headers
	url = https://github.com/microsoft/DirectX-Headers.git
[submodule "External/entt"]
	path = External/entt
	url = https://github.com/skypjack/entt.git
